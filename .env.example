# ══════════════════════════════════════════
#  Exponenta — Environment Configuration
# ══════════════════════════════════════════

# ── Environment ──
ENVIRONMENT=development
DEBUG=true

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://expo:expo@localhost:5432/exponenta

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT Authentication (CHANGE in production!) ──
JWT_SECRET=CHANGE-ME-IN-PRODUCTION

# ── Polygon.io — market data & news ──
POLYGON_API_KEY=your_polygon_api_key_here

# ── Anthropic — Claude for sentiment analysis ──
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional: OpenAI ──
# OPENAI_API_KEY=your_openai_api_key_here

# ── Optional: xAI (Grok) ──
# XAI_API_KEY=your_xai_api_key_here

# ── Optional: NewsAPI ──
# NEWS_API_KEY=your_newsapi_key_here

# ── Optional: X/Twitter social sentiment ──
# TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# ── GPU Cloud: Modal.com (serverless GPU) ──
# MODAL_TOKEN_ID=your_modal_token_id
# MODAL_TOKEN_SECRET=your_modal_token_secret

# ── GPU Cloud: RunPod (persistent/serverless GPU) ──
# RUNPOD_API_KEY=your_runpod_api_key
# RUNPOD_ENDPOINT_ID=your_endpoint_id

# ── Optional: Stripe (payments) ──
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Optional: Apple Push Notifications ──
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=app.exponenta.ios

# ── GPU Settings ──
# GPU_MONTE_CARLO_DEFAULT_SIMS=100000
# GPU_PREFER_CLOUD=false
